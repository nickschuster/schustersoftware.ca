---
import { getCurrentYear } from "../utils/date";
import Logo from "./Logo.astro";
---

<footer
  class="w-full border-t border-zinc-200 dark:border-zinc-800 bg-white/50 dark:bg-[#09090b]/50 py-16 mt-20"
>
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-2 mb-6 group inline-flex">
          <Logo />
          <span
            class="text-xl font-bold tracking-tight text-zinc-900 dark:text-white"
          >
            Schuster Software
          </span>
        </a>
        <p class="text-zinc-600 dark:text-zinc-400 max-w-sm leading-relaxed">
          A suite of modern software applications built with quality, care, and
          a focus on everyday utility.
        </p>
      </div>

      <div>
        <h4 class="font-semibold text-zinc-900 dark:text-white mb-6">
          Navigation
        </h4>
        <ul class="space-y-4 text-sm">
          <li><a href="/#products" class="prose-link">Our Products</a></li>
          <li><a href="/contact" class="prose-link">Contact Us</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-zinc-900 dark:text-white mb-6">
          Connect
        </h4>
        <ul class="space-y-4 text-sm">
          <li>
            <a href="mailto:nick@schustersoftware.ca" class="prose-link">
              Email Support
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div
      class="pt-8 border-t border-zinc-200 dark:border-zinc-800 flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-zinc-500 dark:text-zinc-400"
    >
      <p>© {getCurrentYear()} Schuster Software. All rights reserved.</p>
      <div class="flex gap-6">
        <a
          href="/legal"
          class="hover:text-zinc-900 dark:hover:text-white transition-colors"
          >Legal</a
        >
      </div>
    </div>
  </div>
</footer>
