---
import type { Product } from "../data/products";
import ProductCard from "./ProductCard.astro";
import ProductSearch from "./ProductSearch.astro";

interface Props {
  products: Product[];
}

const { products } = Astro.props;
---

<section
  id="products"
  class="w-full py-8 md:py-12 px-4 animate-slideUp"
  style="animation-delay: 0.1s;"
>
  <div class="max-w-6xl mx-auto">
    <div class="mb-8">
      <ProductSearch />
    </div>

    <div
      id="product-grid"
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6"
    >
      {products.map((product) => <ProductCard product={product} />)}
    </div>

    <div
      id="no-results"
      class="hidden text-center py-20 bg-zinc-50 dark:bg-zinc-900/50 rounded-2xl border border-zinc-200 dark:border-zinc-800"
    >
      <p class="text-zinc-500 dark:text-zinc-400 text-lg font-medium">
        No products found matching your search.
      </p>
    </div>
  </div>
</section>
