  <rect width="32" height="32" rx="8" class="fill-zinc-900 dark:fill-white transition-colors" />
  <path d="M11 21C11 23 13 25 16 25C19 25 21 23 21 21C21 16 11 18 11 13C11 11 13 9 16 9C19 9 21 11 21 13" class="stroke-white dark:stroke-zinc-900 transition-colors" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" fill="none" />
