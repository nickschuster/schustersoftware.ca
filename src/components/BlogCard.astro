---
import type { BlogPost } from "../data/blog";

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;

const formattedDate = new Date(post.date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<a
  href={`/blog/${post.slug}`}
  class="card-container block hover:translate-x-2 transition-transform duration-300 animate-slideUp"
>
  <div class="flex justify-between items-start gap-4 mb-2">
    <h2 class="text-2xl font-bold flex-grow">{post.title}</h2>
    <time class="text-sm text-gray-500 dark:text-gray-400 whitespace-nowrap">
      {formattedDate}
    </time>
  </div>

  <p class="text-gray-700 dark:text-gray-300 mb-4">{post.excerpt}</p>

  <div class="flex items-end justify-between">
    <div class="flex flex-wrap gap-2">
      {
        post.tags.map((tag) => (
          <span class="text-xs font-medium px-2 py-1 rounded bg-gray-200 dark:bg-neutral-700 text-gray-700 dark:text-gray-300">
            {tag}
          </span>
        ))
      }
    </div>
    <span class="text-sm font-semibold text-black dark:text-white">
      Read →
    </span>
  </div>
</a>
