---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getCurrentYear } from "../utils/date";

const lastUpdated = `May 17, ${getCurrentYear()}`;
---

<Layout>
  <Header />
  <main class="min-h-screen flex flex-col">
    <section class="flex-grow py-24 px-4 relative">
      <div
        class="absolute inset-0 z-0 pointer-events-none flex items-center justify-center opacity-30 dark:opacity-20 overflow-hidden"
      >
        <div
          class="w-[600px] h-[600px] bg-gradient-to-tr from-zinc-200 to-transparent dark:from-zinc-800 rounded-full blur-3xl mix-blend-multiply dark:mix-blend-overlay -translate-y-1/2"
        >
        </div>
      </div>

      <div class="max-w-3xl mx-auto relative z-10 animate-fadeIn">
        <h1
          class="text-4xl md:text-5xl font-extrabold mb-4 tracking-tight text-zinc-900 dark:text-white"
        >
          Legal Information
        </h1>
        <p class="text-zinc-600 dark:text-zinc-400 mb-12">
          Last Updated: {lastUpdated}
        </p>

        <div
          class="space-y-12 text-zinc-700 dark:text-zinc-300 leading-relaxed"
        >
          <!-- Privacy Policy -->
          <section>
            <h2
              class="text-2xl font-bold text-zinc-900 dark:text-white mb-6 border-b border-zinc-200 dark:border-zinc-800 pb-2"
            >
              Privacy Policy
            </h2>

            <h3
              class="text-lg font-semibold text-zinc-900 dark:text-white mt-6 mb-3"
            >
              1. Information We Collect
            </h3>
            <p class="mb-4">
              When you use our contact form, we collect the personal information
              you voluntarily provide to us, including your name, email address,
              and the contents of your message. We also automatically collect
              basic analytical data such as IP addresses, browser types, and
              usage patterns to improve our website experience.
            </p>

            <h3
              class="text-lg font-semibold text-zinc-900 dark:text-white mt-6 mb-3"
            >
              2. How We Use Your Information
            </h3>
            <p class="mb-4">
              We use the information collected solely to respond to your
              inquiries, provide customer support, and improve our services. We
              do not sell, rent, or trade your personal information to third
              parties.
            </p>

            <h3
              class="text-lg font-semibold text-zinc-900 dark:text-white mt-6 mb-3"
            >
              3. Data Security
            </h3>
            <p class="mb-4">
              We implement reasonable security measures to protect your personal
              information. However, no electronic transmission over the internet
              or information storage technology can be guaranteed to be 100%
              secure.
            </p>
          </section>

          <!-- Terms of Service -->
          <section>
            <h2
              class="text-2xl font-bold text-zinc-900 dark:text-white mb-6 border-b border-zinc-200 dark:border-zinc-800 pb-2"
            >
              Terms of Service
            </h2>

            <h3
              class="text-lg font-semibold text-zinc-900 dark:text-white mt-6 mb-3"
            >
              1. Acceptance of Terms
            </h3>
            <p class="mb-4">
              By accessing and using schustersoftware.ca ("the Site"), you
              accept and agree to be bound by the terms and provision of this
              agreement. Note that our individual software products and
              applications may have their own specific Terms of Service and
              Privacy Policies which govern their respective usage.
            </p>

            <h3
              class="text-lg font-semibold text-zinc-900 dark:text-white mt-6 mb-3"
            >
              2. Intellectual Property
            </h3>
            <p class="mb-4">
              The Site and its original content, features, and functionality are
              owned by Schuster Software and are protected by international
              copyright, trademark, patent, trade secret, and other intellectual
              property or proprietary rights laws.
            </p>

            <h3
              class="text-lg font-semibold text-zinc-900 dark:text-white mt-6 mb-3"
            >
              3. Disclaimer
            </h3>
            <p class="mb-4">
              The materials on the Site are provided on an 'as is' basis.
              Schuster Software makes no warranties, expressed or implied, and
              hereby disclaims and negates all other warranties including,
              without limitation, implied warranties or conditions of
              merchantability, fitness for a particular purpose, or
              non-infringement of intellectual property or other violation of
              rights.
            </p>

            <h3
              class="text-lg font-semibold text-zinc-900 dark:text-white mt-6 mb-3"
            >
              4. Contact
            </h3>
            <p class="mb-4">
              If you have any questions about these Terms, please contact us via
              our <a href="/contact" class="prose-link">contact page</a>.
            </p>
          </section>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
