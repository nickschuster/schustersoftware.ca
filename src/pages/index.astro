---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
  <Header />
  <main class="min-h-screen flex flex-col">
    <Hero />

    <section
      class="flex-grow flex items-center justify-center px-4 py-20 animate-slideUp"
    >
      <div
        class="max-w-3xl w-full text-center p-12 rounded-3xl border border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-[#0a0a0a]/50 backdrop-blur-sm shadow-xl dark:shadow-black"
      >
        <div
          class="inline-flex items-center gap-2 px-3 py-1 mb-6 rounded-full bg-zinc-200/50 dark:bg-zinc-800/80 border border-zinc-300 dark:border-zinc-700/50 text-sm font-medium text-zinc-700 dark:text-zinc-300"
        >
          <span
            class="w-2 h-2 rounded-full bg-zinc-900 dark:bg-zinc-100 animate-pulse-slow"
          ></span>
          Under Construction
        </div>
        <h2
          class="text-4xl md:text-5xl font-extrabold text-zinc-900 dark:text-white mb-4 tracking-tight"
        >
          Exciting things are coming.
        </h2>
        <p
          class="text-lg text-zinc-600 dark:text-zinc-400 mb-8 max-w-xl mx-auto"
        >
          We are currently building a new suite of smart tools. Check back soon
          for our first release, or get in touch if you want to collaborate.
        </p>
      </div>
    </section>

    <!-- Hiding Product Grid for now during rebuild -->
    <!-- <ProductGrid products={products} /> -->
  </main>
  <Footer />
</Layout>
