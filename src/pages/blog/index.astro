---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import BlogCard from "../../components/BlogCard.astro";
import { blogPosts } from "../../data/blog.ts";

// Sort by date, newest first
const sortedPosts = blogPosts.sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime(),
);
---

<Layout>
  <Header />
  <main class="min-h-screen flex flex-col">
    <section class="py-16 md:py-24 px-4">
      <div class="max-w-4xl mx-auto">
        <div class="mb-12 animate-fadeIn">
          <h1 class="text-4xl md:text-5xl font-bold mb-4">Blog</h1>
          <p class="text-xl text-gray-600 dark:text-gray-400">
            Thoughts, updates, and insights about software development and our
            products.
          </p>
        </div>

        <div class="space-y-6">
          {sortedPosts.map((post) => <BlogCard post={post} />)}
        </div>

        {
          sortedPosts.length === 0 && (
            <div class="text-center py-12">
              <p class="text-gray-500 dark:text-gray-400 text-lg">
                No blog posts yet. Check back soon!
              </p>
            </div>
          )
        }
      </div>
    </section>
  </main>
  <Footer />
</Layout>
